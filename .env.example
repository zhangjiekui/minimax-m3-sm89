# Copy to .env and edit for your machine.
# Required: where you downloaded olka-fi/MiniMax-M3-MXFP4.
# Download with:
#   huggingface-cli download olka-fi/MiniMax-M3-MXFP4 --local-dir /data/models/MiniMax-M3-MXFP4
MODEL_DIR=/data/models/MiniMax-M3-MXFP4
MODELS_ROOT=/data/models

# Optional tuning (defaults shown):
# MAX_MODEL_LEN=250000
# GPU_UTIL=0.92
# TP=4
# PORT=8000
# MAX_NUM_BATCHED_TOKENS=8192
# MAX_NUM_SEQS=4
